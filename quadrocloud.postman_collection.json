    {
      "name": "Payments",
      "item": [
        {
          "name": "List Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payments", "host": ["{{base_url}}"], "path": ["api", "v1", "payments"] }
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/payments/1", "host": ["{{base_url}}"], "path": ["api", "v1", "payments", "1"] }
          }
        },
        {
          "name": "Initiate Payment (Paymob)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoice_id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/payments/initiate", "host": ["{{base_url}}"], "path": ["api", "v1", "payments", "initiate"] }
          }
        },
        {
          "name": "Verify Payment (app-side)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymob_order_id\": \"<paymob-order-id>\",\n  \"transaction_id\": \"<txn-id>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/payments/verify", "host": ["{{base_url}}"], "path": ["api", "v1", "payments", "verify"] }
          }
        },
        {
          "name": "Payment Callback (Paymob redirect — public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/payments/callback?id=<txn-id>&success=true&amount_cents=10000&order=<order-id>&hmac=<hmac>",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payments", "callback"],
              "query": [
                { "key": "id", "value": "<txn-id>" },
                { "key": "success", "value": "true" },
                { "key": "amount_cents", "value": "10000" },
                { "key": "order", "value": "<order-id>" },
                { "key": "hmac", "value": "<hmac>" }
              ]
            }
          }
        },
        {
          "name": "Paymob Webhook (server-to-server — public)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"TRANSACTION\",\n  \"obj\": {\n    \"id\": 123456,\n    \"success\": true,\n    \"amount_cents\": 10000,\n    \"special_reference\": \"INV-1\",\n    \"order\": { \"id\": \"<paymob-order-id>\" }\n  },\n  \"hmac\": \"<hmac>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/webhooks/paymob", "host": ["{{base_url}}"], "path": ["api", "v1", "webhooks", "paymob"] }
          }
        }
      ]
    },
