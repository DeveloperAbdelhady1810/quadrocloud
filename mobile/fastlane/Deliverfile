app_identifier "com.quadrocloud.app"

# Metadata
metadata_path "./fastlane/metadata"
screenshots_path "./fastlane/screenshots"

# App Store settings
primary_category "BUSINESS"
content_rating({
  "APPLE_ID_SAFE_HARBOR_POLICY"          => "false",
  "KIDS_AGE_BAND"                        => nil,
  "CARTOON_FANTASY_VIOLENCE"             => "NONE",
  "REALISTIC_VIOLENCE"                   => "NONE",
  "PROLONGED_GRAPHIC_SADISTIC_REALISTIC_VIOLENCE" => "NONE",
  "PROFANITY_CRUDE_HUMOR"               => "NONE",
  "MATURE_SUGGESTIVE"                   => "NONE",
  "HORROR_FEAR_THEMES"                  => "NONE",
  "MEDICAL_TREATMENT_INFO"              => "NONE",
  "ALCOHOL_TOBACCO_DRUGS"               => "NONE",
  "GAMBLING"                            => "NONE",
  "SEXUAL_CONTENT_NUDITY"              => "NONE",
  "GRAPHIC_SEXUAL_CONTENT_NUDITY"      => "NONE",
  "UNRESTRICTED_WEB_ACCESS"            => "false",
  "GAMBLING_CONTESTS"                  => "false",
})

# Locales to submit
languages ["en-US", "ar-SA"]

# Skip binary upload (metadata only)
skip_binary_upload true
skip_screenshots false

# Auto submit after metadata upload
submit_for_review false
automatic_release false

force true
